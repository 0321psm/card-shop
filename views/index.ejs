<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>卡片商店</title>
  <style>
    body { font-family: Arial, sans-serif; padding: 20px; background: #f8f9fa; }
    .search-box { margin-bottom: 20px; display: flex; gap: 10px; align-items: center; flex-wrap: wrap; background: white; padding: 12px 18px; border-radius: 8px; box-shadow: 0 2px 5px rgba(0,0,0,0.05); }
    .search-box input { flex:1; padding: 10px 14px; border-radius: 6px; border: 1px solid #ddd; font-size: 16px; min-width: 200px; }
    .search-box button { background: #3498db; color: white; border: none; padding: 10px 20px; border-radius: 6px; cursor: pointer; font-size: 16px; }
    .grid { display: flex; flex-wrap: wrap; gap: 20px; justify-content: flex-start; }
    .card { border: 1px solid #ddd; padding: 15px; border-radius: 10px; width: 200px; background: white; box-shadow: 0 2px 5px rgba(0,0,0,0.05); }
    .card img { width: 100%; height: 150px; object-fit: cover; border-radius: 6px; }
    .card h3 { margin: 10px 0 5px; font-size: 16px; }
    .card .code { color: #666; font-size: 13px; }
    .card .category { display: inline-block; background: #ecf0f1; padding: 2px 10px; border-radius: 12px; font-size: 12px; color: #2c3e50; margin: 4px 0; }
    .card .price { color: #e67e22; font-weight: bold; font-size: 18px; }
    .card .stock { font-size: 13px; color: #27ae60; }
    button { background: #3498db; color: white; border: none; padding: 8px 16px; border-radius: 6px; cursor: pointer; }
    button:hover { opacity: 0.8; }
    .cart-bar { position: fixed; bottom: 20px; right: 20px; background: #2c3e50; color: white; padding: 15px 25px; border-radius: 50px; box-shadow: 0 4px 10px rgba(0,0,0,0.3); }
    .cart-bar a { color: white; text-decoration: none; font-weight: bold; }
    .no-result { text-align: center; color: #999; font-size: 18px; padding: 40px; }
  </style>
</head>
<body>
  <h1>🃏 所有卡片</h1>

  <!-- 搜尋列 -->
  <div class="search-box">
    <input type="text" id="searchInput" placeholder="輸入卡片編號或名稱..." onkeyup="filterCards()">
    <button onclick="filterCards()">🔍 搜尋</button>
    <button onclick="document.getElementById('searchInput').value=''; filterCards();" style="background:#95a5a6;">清除</button>
  </div>

  <div class="grid" id="cardGrid">
    <% cards.forEach(c => { %>
      <div class="card" data-code="<%= c.card_code.toLowerCase() %>" data-name="<%= c.name.toLowerCase() %>">
        <img src="<%= c.image_url || '/uploads/default.jpg' %>" alt="<%= c.name %>">
        <h3><%= c.name %></h3>
        <div class="code">編號：<%= c.card_code %></div>
        <div class="category"><%= c.category || '未分類' %></div>
        <div class="price">$<%= c.price %></div>
        <div class="stock">📦 庫存：<%= c.stock %></div>
        <button onclick="addToCart('<%= c.card_code %>','<%= c.name %>',<%= c.price %>,<%= c.stock %>)">加入購物車</button>
      </div>
    <% }) %>
  </div>

  <div class="cart-bar">
    <a href="/checkout">🛒 去結帳</a>
  </div>

  <script>
    let cart = [];
    function addToCart(code, name, price, stock) {
      if (stock <= 0) return alert('庫存不足');
      const existing = cart.find(i => i.card_code === code);
      if (existing) existing.qty++;
      else cart.push({ card_code: code, name, price, qty: 1 });
      alert('✅ 已加入購物車');
      localStorage.setItem('cart', JSON.stringify(cart));
    }

    function filterCards() {
      const keyword = document.getElementById('searchInput').value.toLowerCase().trim();
      const cards = document.querySelectorAll('.card');
      let visible = 0;
      cards.forEach(card => {
        const code = card.getAttribute('data-code') || '';
        const name = card.getAttribute('data-name') || '';
        if (code.includes(keyword) || name.includes(keyword)) {
          card.style.display = '';
          visible++;
        } else {
          card.style.display = 'none';
        }
      });
      const grid = document.getElementById('cardGrid');
      let noMsg = document.getElementById('noResultMsg');
      if (visible === 0) {
        if (!noMsg) {
          noMsg = document.createElement('div');
          noMsg.id = 'noResultMsg';
          noMsg.className = 'no-result';
          noMsg.innerText = '😅 找不到符合的卡片，試試其他關鍵字吧！';
          grid.appendChild(noMsg);
        }
      } else {
        if (noMsg) noMsg.remove();
      }
    }
  </script>
</body>
</html>